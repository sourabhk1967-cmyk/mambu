{
  "name": "kyrovia-backend",
  "version": "1.0.0",
  "private": true,
  "description": "Express backend for the Kyrovia browser workspace.",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "test": "node --test",
    "playwright:install": "npx playwright install --with-deps chromium"
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "config.js",
      "middleware",
      "routes",
      "services"
    ],
    "ext": "js",
    "ignore": [
      "data/**",
      "logs/**",
      "playwright-profile/**",
      "node_modules/**",
      "*.log",
      "*.out.log",
      "*.err.log"
    ]
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^7.0.0-rc13",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^8.1.0",
    "firebase-admin": "^13.10.0",
    "fs-extra": "^11.3.5",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "playwright": "^1.49.1",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
