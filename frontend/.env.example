# Use /api when frontend and backend are deployed together.
VITE_API_URL=http://localhost:5050/api
VITE_AI_TIMEOUT_MS=3900000
# Switch to fallback result polling when a proxy buffers generation events for this long.
# Normal chat delivery starts a low-frequency recovery safety net after a short delay.
VITE_GENERATION_STREAM_IDLE_TIMEOUT_MS=25000

# Optional: point production static assets at a Cloudflare CDN/custom domain.
# Example: VITE_CLOUDFLARE_CDN_URL=https://cdn.example.com/kyrovia/
VITE_CLOUDFLARE_CDN_URL=

